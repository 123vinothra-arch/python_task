# Workout Tracker mini project

workouts = []

while True:
    print("\n--- Workout Tracker ---")
    print("1. Add workout")
    print("2. View workouts")
    print("3. Exit")

    choice = input("Choose an option: ")

    if choice == "1":
        exercise = input("Exercise name: ")
        minutes = input("Duration in minutes: ")

        workouts.append({
            "exercise": exercise,
            "minutes": minutes
        })

        print("Workout added!")

    elif choice == "2":
        if not workouts:
            print("No workouts recorded yet.")
        else:
            print("\nYour Workouts:")
            for number, workout in enumerate(workouts, start=1):
                print(f"{number}. {workout['exercise']} - {workout['minutes']} minutes")

    elif choice == "3":
        print("Keep training! Goodbye.")
        break

    else:
        print("Please enter 1, 2, or 3.")
